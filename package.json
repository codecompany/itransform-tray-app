{
  "name": "pulsetray",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "PulseTray desktop client for Sintonia",
  "author": "Code Company",
  "main": "dist/main/electron/main.js",
  "scripts": {
    "build:preload": "node -e \"const fs=require('fs'); fs.rmSync('dist/main',{recursive:true,force:true}); fs.mkdirSync('dist/main/electron',{recursive:true})\" && esbuild electron/preload.ts --bundle --platform=node --format=cjs --outfile=dist/main/electron/preload.cjs --external:electron --tsconfig=tsconfig.json",
    "dev": "npm run build:preload && concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -w -p electron/tsconfig.json",
    "dev:electron": "wait-on http://localhost:4185 && cross-env ELECTRON_ENV=dev VITE_DEV_SERVER_URL=http://localhost:4185 electron scripts/electron-launcher.cjs",
    "build": "npm run build:preload && npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p electron/tsconfig.json",
    "dist:mac": "bash ./scripts/build-release.sh --platform mac",
    "dist:mac:dir": "bash ./scripts/build-release.sh --platform mac --dir",
    "dist:win": "bash ./scripts/build-release.sh --platform win --arch x64",
    "typecheck": "tsc --noEmit && tsc --noEmit -p electron/tsconfig.json",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "check:imports": "node scripts/forbidden-imports.mjs",
    "check:workflows": "node scripts/validate-workflows.cjs",
    "pack:dry-run": "cd npm-package && npm --cache ../.cache/npm pack --dry-run",
    "smoke:npm": "node npm-package/test/smoke.cjs"
  },
  "build": {
    "appId": "com.codecompany.sintonia.pulsetray",
    "productName": "PulseTray",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/main/**",
      "dist/renderer/**",
      "assets/**",
      "package.json"
    ],
    "asar": true,
    "afterPack": "scripts/after-pack.cjs",
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "artifactName": "PulseTray-Setup-${version}-windows-${arch}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true
    },
    "portable": {
      "artifactName": "PulseTray-${version}-windows-${arch}-portable.${ext}"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.png",
      "artifactName": "PulseTray-${version}-mac-${arch}.${ext}"
    }
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.0.16",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^39.2.7",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "jsdom": "^27.3.0",
    "tsx": "^4.20.6",
    "typescript": "^5.4.2",
    "vite": "^7.3.0",
    "vitest": "^4.0.16",
    "wait-on": "^7.2.0",
    "yaml": "^2.8.1"
  },
  "engines": {
    "node": ">=20"
  },
  "allowScripts": {
    "electron@39.8.10": true,
    "electron-winstaller@5.4.0": true,
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true
  }
}
